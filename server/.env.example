# Ghost Companion data API — environment.
# On Railway, set these as service variables (PORT is provided automatically).

# Required for all Bungie calls.
BUNGIE_API_KEY=your_bungie_api_key

# Confidential OAuth client (the same app the desktop client uses).
BUNGIE_CLIENT_ID=53355
BUNGIE_CLIENT_SECRET=your_rotated_client_secret

# Service account's refresh token — obtain once via `npm run mint-token`
# (sign into the desktop app with the service account first).
BUNGIE_REFRESH_TOKEN=

# Optional manual override when the vendor heuristic is wrong for a given week.
# JSON of itemHashes, e.g. {"nightfall":4289226715,"trials":2362652544}
# ROTATION_OVERRIDE_JSON=
