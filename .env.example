# =============================================================================
# Ghost Companion — environment configuration
# Copy this file to ".env" and fill in your own values.
# Create a Bungie application at: https://www.bungie.net/en/Application
# =============================================================================

# Your Bungie API key (required for ALL requests, including the Manifest).
BUNGIE_API_KEY=your_bungie_api_key_here

# OAuth client ID from your Bungie application page.
BUNGIE_CLIENT_ID=your_oauth_client_id_here

# OAuth client secret. Required only for "Confidential" OAuth apps.
# Leave blank for a "Public" OAuth client.
BUNGIE_CLIENT_SECRET=your_oauth_client_secret_here

# The redirect URL registered on your Bungie application page. MUST match exactly.
# Ghost Companion runs a self-signed HTTPS loopback server at this address to
# capture the OAuth code (Bungie requires HTTPS, even on localhost).
BUNGIE_REDIRECT_URL=https://127.0.0.1:7777/callback
